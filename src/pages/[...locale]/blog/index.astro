---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import { getLocalizedStaticPaths, getRouteLocale } from "../../../lib/i18n-routing";
import { toLocalizedPath } from "../../../lib/routes";

export function getStaticPaths() {
  return getLocalizedStaticPaths();
}

const locale = getRouteLocale(Astro.params.locale);
const posts = (await getCollection("blog"))
  .filter((p) => p.data.locale === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Latest writing." locale={locale}>
  <section class="shell blog-list">
    <h1>Blog</h1>
    {posts.length === 0 && (
      <p class="empty">No posts yet. Add some to <code>src/content/blog/</code>.</p>
    )}
    <ul>
      {posts.map((post) => (
        <li>
          <a href={toLocalizedPath(`/blog/${post.id}/`, locale)}>
            <h2>{post.data.title}</h2>
            <p class="meta">
              <FormattedDate date={post.data.pubDate} locale={locale} />
            </p>
            <p>{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .blog-list {
    padding: 48px 0 64px;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 32px;
  }
  ul {
    list-style: none;
    display: grid;
    gap: 24px;
  }
  li a {
    display: block;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg);
  }
  li a:hover {
    text-decoration: none;
    border-color: var(--accent);
  }
  h2 {
    font-size: 1.4rem;
    margin-bottom: 8px;
  }
  .meta {
    color: var(--muted);
    font-family: var(--ff-ui);
    font-size: 13px;
    margin-bottom: 8px;
  }
  .empty {
    color: var(--muted);
  }
</style>
