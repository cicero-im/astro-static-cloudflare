---
import { getCollection, render } from "astro:content";
import BlogPost from "../../../layouts/BlogPost.astro";
import { getLocalizedSlugStaticPaths, getRouteLocale } from "../../../lib/i18n-routing";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return getLocalizedSlugStaticPaths(posts, "post");
}

const locale = getRouteLocale(Astro.params.locale);
const { post } = Astro.props as { post: Awaited<ReturnType<typeof getCollection<"blog">>>[number] };
const { Content } = await render(post);
---

<BlogPost post={post} locale={locale}>
  <Content />
</BlogPost>
