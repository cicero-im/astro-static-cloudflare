---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLocalizedStaticPaths, getRouteLocale } from "../../lib/i18n-routing";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

export function getStaticPaths() {
  return getLocalizedStaticPaths();
}

const locale = getRouteLocale(Astro.params.locale);
---

<BaseLayout title="Home" description={SITE_DESCRIPTION} locale={locale}>
  <section class="hero shell">
    <h1>{SITE_TITLE}</h1>
    <p class="lead">{SITE_DESCRIPTION}</p>
    <p class="cta">
      <a href="/blog/">Read the blog</a>
      &nbsp;·&nbsp;
      <a href="/docs/">View the docs</a>
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: clamp(48px, 10vw, 120px) 0;
    text-align: center;
  }
  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .lead {
    margin-top: 16px;
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 60ch;
    margin-inline: auto;
  }
  .cta {
    margin-top: 32px;
    font-family: var(--ff-ui);
  }
</style>
